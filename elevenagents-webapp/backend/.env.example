# ───────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Get an API key at https://elevenlabs.io/app/settings/api-keys
# ───────────────────────────────────────────────────────────────────────────

# REQUIRED — your ElevenLabs API key. Stays server-side only; never shipped to
# the browser. Used by the provisioning script (provision_agent.py) and to
# verify configuration in the backend health check.
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE

# The Agents (Conversational AI) agent the frontend connects to.
# Leave blank and run `python provision_agent.py` to create one automatically —
# the script writes the resulting id back here. Or paste an existing agent id.
ELEVENLABS_AGENT_ID=

# ───────────────────────────────────────────────────────────────────────────
# Provisioning options (only used by provision_agent.py)
# ───────────────────────────────────────────────────────────────────────────

# Display name for the agent created by the provisioning script.
AGENT_NAME=Aerial SG Concierge

# Voice used by the agent's TTS. Default is a calm, premium-sounding voice.
# Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Embedding model used to build the RAG index over your knowledge-base files.
ELEVENLABS_RAG_EMBEDDING_MODEL=e5_mistral_7b_instruct
